{
	"name": "backend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"build": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy --dry-run --outdir dist",
		"deploy": "WRANGLER_LOG_PATH=.wrangler/logs wrangler deploy",
		"setup:d1": "WRANGLER_LOG_PATH=.wrangler/logs wrangler d1 create r-listener",
		"setup:r2": "WRANGLER_LOG_PATH=.wrangler/logs wrangler r2 bucket create r-listener-audio",
		"setup:kv": "WRANGLER_LOG_PATH=.wrangler/logs wrangler kv namespace create r-listener-cache",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "WRANGLER_LOG_PATH=.wrangler/logs wrangler d1 migrations apply r-listener --remote",
		"compile": "tsc --noEmit",
		"typecheck": "tsc --noEmit",
		"test": "npm run test:unit",
		"test:unit": "vitest run",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"drizzle-orm": "^0.45.2",
		"hash-wasm": "^4.12.0",
		"hono": "^4.9.10",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260401.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "^5.7.0",
		"vitest": "^4.1.5",
		"wrangler": "^4.0.0"
	}
}
